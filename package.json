{
  "name": "persia-chat",
  "version": "5.0.0",
  "description": "گپ گروهی لوکس با قابلیت تبدیل به APK",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:pwa": "pwa2apk --input ./public --output ./apk --name 'گپ گروهی' --version 5.0.0",
    "build:android": "npx cap copy && npx cap open android"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pwa2apk": "^1.0.0",
    "@capacitor/core": "^5.0.0",
    "@capacitor/cli": "^5.0.0",
    "@capacitor/android": "^5.0.0"
  }
}
